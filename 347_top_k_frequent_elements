# LeetCode 347
# Top K Frequent Elements
# Difficulty: Medium
# Time: O(n log n)
# Space: O(n)

class Solution(object):
    def topKFrequent(self, nums, k):
        """
        :type nums: List[int]
        :type k: int
        :rtype: List[int]
        """

        result = {}

        for num in nums:
            result[num] = result.get(num, 0) + 1
        
        final = list(result.items())
        final.sort(reverse = True, key = lambda x: x[1])
        return [final[i][0] for i in range(k)]